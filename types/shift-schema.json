{
  "title": "Shift",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid"
    },
    "user_id": {
      "type": "string",
      "format": "uuid"
    },
    "date": {
      "type": "string",
      "format": "date"
    },
    "start_time": {
      "type": "string",
      "format": "time"
    },
    "end_time": {
      "type": "string",
      "format": "time"
    },
    "break_minutes": {
      "type": "integer",
      "minimum": 0
    },
    "status": {
      "type": "string",
      "enum": ["pending", "validated", "rejected"]
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    }
  },
  "required": ["id", "user_id", "date", "start_time", "end_time", "break_minutes", "status", "created_at"]
}
